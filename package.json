{
  "name": "punchless",
  "version": "0.1.0",
  "private": true,
  "description": "Workshop Attendance SaaS — Automatic GPS-based attendance, job tracking & salary management",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "mobile:doctor": "npx expo-doctor apps/mobile",
    "db:gen-types": "npx supabase gen types typescript --project-id hrjarkhzmhgdrlkzpkka > packages/types/src/database.types.ts",
    "db:push": "npx supabase db push",
    "db:pull": "npx supabase db pull",
    "db:reset": "npx supabase db reset",
    "db:migration:new": "npx supabase migration new",
    "db:diff": "npx supabase db diff",
    "db:status": "npx supabase migration list --project-id hrjarkhzmhgdrlkzpkka",
    "db:seed-shahin-employees": "node scripts/seed-shahin-employees.mjs",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "metro-runtime": "^0.83.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
